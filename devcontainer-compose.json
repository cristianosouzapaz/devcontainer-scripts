{
    "customizations": {
        "vscode": {
            "extensions": [
                "Anthropic.claude-code",
                "bierner.markdown-mermaid",
                "GitHub.copilot-chat",
                "GitHub.vscode-pull-request-github",
                "redhat.vscode-yaml",
                "yzhang.markdown-all-in-one"
            ]
        }
    },
    "dockerComposeFile": [
        "docker-compose.yml"
    ],
    "name": "project-name",
    "postCreateCommand": "/opt/devcontainer/devcontainer-setup.sh",
    "remoteEnv": {
        "AUTO_UPDATE": "true",
        "CLEAN_CREDENTIALS": "false",
        "DEBUG_MODE": "false",
        "DEFAULT_BRANCH": "main",
        "DUMP_ERROR_STACK": "true",
        "GIT_EMAIL": "cristiano.souzapaz@gmail.com",
        "GIT_USER": "cristianosouzapaz",
        "LOG_FILE": "/tmp/setup.log",
        "LOG_LEVEL": "INFO",
        "PROJECT_NAME": "project-name",
        "REPO_SOURCE": "",
        "SSH_SIGNING": "true",
        "STRUCTURED_LOGS": "false",
        "VALIDATE_TOKEN": "true"
    },
    "remoteUser": "root",
    "service": "project-name",
    "workspaceFolder": "/workspace/project-name"
}