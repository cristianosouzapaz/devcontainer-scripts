# This file defines Git attribute rules for line-ending normalization
# and marks binary files to prevent unwanted content conversion.
# Version 1.0

# Set default behavior to automatically normalize line endings.
* text=auto eol=lf

# Explicitly declare text files to be normalized and converted to native line endings on checkout.
*.md text eol=lf
*.txt text eol=lf
*.js text eol=lf
*.cjs text eol=lf
*.mjs text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.jsonc text eol=lf
*.xml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.sh text eol=lf
*.ps1 text eol=lf
Dockerfile text eol=lf

# lockfiles should remain text and LF-normalized
package-lock.json text eol=lf
yarn.lock text eol=lf
pnpm-lock.yaml text eol=lf

# Windows-specific files that should retain CRLF line endings
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files that should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.zip binary
*.gz binary
*.7z binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary