[
    {
        "label": "Common Utils",
        "key": "common-utils",
        "mandatory": true,
        "feature": {
            "url": "ghcr.io/devcontainers/features/common-utils:2",
            "options": {
                "installZsh": false,
                "username": "root",
                "userUid": "0",
                "userGid": "0",
                "upgradePackages": false
            }
        }
    },
    {
        "label": "Git",
        "key": "git",
        "mandatory": true,
        "feature": {
            "url": "ghcr.io/devcontainers/features/git:1",
            "options": {}
        }
    },
    {
        "label": "Node.js + pnpm",
        "key": "node",
        "mandatory": true,
        "feature": {
            "url": "ghcr.io/devcontainers/features/node:1",
            "options": {
                "version": "lts",
                "pnpmVersion": "latest"
            }
        }
    },
    {
        "label": "Docker (outside-of-docker)",
        "key": "docker",
        "default": true,
        "mandatory": false,
        "feature": {
            "url": "ghcr.io/devcontainers/features/docker-outside-of-docker:1",
            "options": {
                "composeVersion": "latest",
                "enableNonRootDocker": false,
                "installDockerCompose": true,
                "version": "latest"
            }
        },
        "mount": "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
    },
    {
        "label": "PostgreSQL client",
        "key": "psql",
        "default": false,
        "mandatory": false,
        "feature": {
            "url": "ghcr.io/robbert229/devcontainer-features/postgresql-client:1",
            "options": {
                "version": "18"
            }
        }
    },
    {
        "label": "uv (Python package manager)",
        "key": "uv",
        "default": false,
        "mandatory": false,
        "feature": {
            "url": "ghcr.io/va-h/devcontainers-features/uv:1",
            "options": {
                "version": "latest"
            }
        }
    },
    {
        "label": "ngrok (HTTP tunneling)",
        "key": "ngrok",
        "default": false,
        "mandatory": false,
        "feature": {
            "url": "ghcr.io/jckimble/devcontainer-features/ngrok:3",
            "options": {}
        }
    },
    {
        "label": "SSH Commit Signing (1Password)",
        "key": "ssh-signing",
        "default": true,
        "mandatory": false,
        "feature": null
    }
]